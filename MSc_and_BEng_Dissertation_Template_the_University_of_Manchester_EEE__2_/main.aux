\@writefile{lof}{\contentsline {figure}{\numberline {1}{\ignorespaces Deep reinforcement learning framework. (a) The RL interaction loop: the DQN agent selects actions (N/S/E/W/Hover) based on the current state and receives a reward signal encoding data throughput, fairness, and energy consumption. (b) The DQN network architecture with fully connected layers [512, 512, 256] and ReLU activations, mapping a 1530-dimensional frame-stacked state to Q-values for five actions. (c) The complete Deep Q-Learning system, combining the RL loop with experience replay buffer and a frozen target network $\hat  {Q}(s,a;\theta ^{-})$ for training stability.}}{24}{figure.caption.8}\protected@file@percent }
\newlabel{fig:drl_architecture}{{1}{24}{Deep reinforcement learning framework. (a) The RL interaction loop: the DQN agent selects actions (N/S/E/W/Hover) based on the current state and receives a reward signal encoding data throughput, fairness, and energy consumption. (b) The DQN network architecture with fully connected layers [512, 512, 256] and ReLU activations, mapping a 1530-dimensional frame-stacked state to Q-values for five actions. (c) The complete Deep Q-Learning system, combining the RL loop with experience replay buffer and a frozen target network $\hat {Q}(s,a;\theta ^{-})$ for training stability}{figure.caption.8}{}}
